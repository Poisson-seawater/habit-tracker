FROM python:3.12-slim

WORKDIR /app

# All runtime deps ship as pure-Python / manylinux wheels (incl. aarch64),
# so no compiler toolchain is needed. SQLite is bundled with Python.

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy backend files
COPY . .

EXPOSE 5000

ENV PYTHONPATH=/app/src
CMD ["uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "5000"]
