# pyenv
#   For a library or package, you might want to ignore these files since the code is
#   intended to run in multiple environments; otherwise, check them in:
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if used in a clean env:
#   Pipfile.lock might be ignored if desired.

# poetry
#   Poetry uses pyproject.toml to manage dependencies and version control.
#   According to poetry/poetry#660, poetry.lock should be committed.

# pdm
#   PDM stores project-local configurations in .pdm-python and PDM_DEP_DIR
.pdm-python
.pdm-build/

