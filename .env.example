# Telegram configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_GROUP_ID=your_telegram_group_id_here

# Server configuration
API_PORT=5000
ENV=production
AUTH_BOOTSTRAP_CODE=change-this-one-time-setup-code
HABIT_API_TOKEN=change-this-machine-api-token
AUTH_SESSION_DAYS=30
AUTH_COOKIE_SECURE=false

# Google Calendar & Tasks Integration Configuration
# Obtain these from the Google Cloud Console (APIs & Services > Credentials)
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
# Default is http://localhost:5000/api/v1/auth/google/callback
GOOGLE_REDIRECT_URI=http://localhost:5000/api/v1/auth/google/callback
GOOGLE_ENCRYPTION_KEY=default-habit-tracker-key-12345

# SQLite persistent database inside Docker
DATABASE_URL=sqlite:////data/habit_tracker.db
